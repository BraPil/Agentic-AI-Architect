# Wiki is curated knowledge — tracked as source, not generated artifacts
!data/wiki/
!data/wiki/**
*.db
*.sqlite
*.sqlite3

# Environment files (NEVER commit credentials)
.env
*.env.local

# Cookie files (contain live auth tokens — never commit)
cookies.txt
*cookies*.txt

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS artifacts
.DS_Store
Thumbs.db

# FAISS indexes
*.faiss
*.pkl

