# Environment variables for Agentic AI Architect
# ================================================
# Copy this file to .env and fill in your API keys
# NEVER commit your actual .env file to source control!

# LLM Provider API Keys (optional — system runs without them using heuristics)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# FIRECRAWL_API_KEY=fc-...

# Storage paths (optional — defaults to ./data/)
# AAA_DATA_DIR=data
# AAA_KNOWLEDGE_DB=data/knowledge_base.db
# AAA_VECTOR_STORE_DIR=data/vector_store
# AAA_OUTPUT_DIR=data/output

# Crawler settings (optional)
# AAA_CRAWLER_TIMEOUT=15
# AAA_CRAWLER_RATE_LIMIT=1.0
# AAA_CRAWLER_ROBOTS_TXT=true

# LLM settings (optional)
# AAA_DEFAULT_LLM_MODEL=claude-3-5-haiku-20241022
# AAA_FAST_LLM_MODEL=claude-3-haiku-20240307
# AAA_EMBEDDING_MODEL=text-embedding-3-small

# Trend thresholds (optional)
# AAA_TREND_NEW_THRESHOLD=7.0
# AAA_TREND_DECLINE_THRESHOLD=5.0
# AAA_TREND_BREAKTHROUGH_DELTA=2.0

# Orchestrator settings (optional)
# AAA_MAX_CYCLE_ERRORS=3
# AAA_CYCLE_INTERVAL_HOURS=24
# AAA_LOG_LEVEL=INFO
